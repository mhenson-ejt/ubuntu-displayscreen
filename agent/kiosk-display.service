[Unit]
Description=Kiosk camera display (X + mpv)
Conflicts=getty@tty1.service
After=systemd-user-sessions.service getty@tty1.service

[Service]
User=@KIOSK_USER@
PAMName=login
TTYPath=/dev/tty1
TTYReset=yes
TTYVHangup=yes
TTYVTDisallocate=yes
StandardInput=tty
StandardOutput=journal
StandardError=journal
ExecStart=/usr/bin/startx /etc/kiosk/cams.sh -- :0 vt1 -keeptty -nocursor
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
