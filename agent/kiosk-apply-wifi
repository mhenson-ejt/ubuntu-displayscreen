#!/bin/bash
#===============================================================================
# kiosk-apply-wifi - configures the screen's WiFi network via netplan
#
# Usage:
#   kiosk-apply-wifi SSID [PSK]     configure (open network if PSK omitted)
#   kiosk-apply-wifi --clear        remove the WiFi config
#
# Design: the WiFi is configured PERMANENTLY with a worse route metric than
# wired (wired DHCP routes get systemd-networkd's default metric 1024; ours is
# 4096). The kernel therefore uses wired whenever a cable is connected and
# falls over to WiFi the moment the wired route disappears - and back again
# when the cable returns. No carrier-watching daemon needed, and WiFi-only
# screens simply use it as their main connection.
#
# Idempotent: if the generated netplan file is unchanged, nothing is touched
# (so the agent can call this on every config refresh without network blips -
# 'netplan apply' briefly reconfigures interfaces, so it only runs on change).
#===============================================================================
set -euo pipefail

YAML=/etc/netplan/90-kiosk-wifi.yaml
WAIT_ONLINE_DIR=/etc/systemd/system/systemd-networkd-wait-online.service.d
WAIT_ONLINE_CONF=$WAIT_ONLINE_DIR/10-kiosk-any.conf

log() { echo "kiosk-apply-wifi: $*"; }

# With two managed paths (wired + WiFi), booting with either one up must not stall on the other:
# wait-online defaults to requiring ALL managed interfaces, so an unplugged cable would hold boot
# for its ~2 min timeout. --any is correct whenever WiFi is configured; removed again on --clear.
install_wait_online_any() {
  [[ -f $WAIT_ONLINE_CONF ]] && return 0
  mkdir -p "$WAIT_ONLINE_DIR"
  cat > "$WAIT_ONLINE_CONF" <<'EOF'
# Installed by kiosk-apply-wifi: with wired + WiFi both managed, boot must proceed when EITHER
# is online (an unplugged cable would otherwise stall boot for the wait-online timeout).
[Service]
ExecStart=
ExecStart=/lib/systemd/systemd-networkd-wait-online --any
EOF
  systemctl daemon-reload
  log "wait-online set to --any (boot proceeds when either network path is up)"
}

remove_wait_online_any() {
  [[ -f $WAIT_ONLINE_CONF ]] || return 0
  rm -f "$WAIT_ONLINE_CONF"
  rmdir --ignore-fail-on-non-empty "$WAIT_ONLINE_DIR"
  systemctl daemon-reload
  log "wait-online restored to default"
}

if [[ ${1:-} == --clear ]]; then
  remove_wait_online_any
  if [[ -f $YAML ]]; then
    rm -f "$YAML"
    netplan apply
    log "WiFi config removed"
  fi
  exit 0
fi

SSID=${1:-}
PSK=${2:-}
[[ -n $SSID ]] || { log "usage: kiosk-apply-wifi SSID [PSK] | --clear"; exit 1; }

# WPA-PSK passphrases must be 8-63 characters; refuse rather than write a
# config wpa_supplicant will reject
if [[ -n $PSK && ( ${#PSK} -lt 8 || ${#PSK} -gt 63 ) ]]; then
  log "refusing: WiFi password must be 8-63 characters"
  exit 1
fi

# netplan's networkd backend requires WiFi devices by literal interface name (match: is not
# supported for wifis) - detect it at apply time. Pure sysfs: no dependency on iw/wireless-tools,
# which minimal server installs don't have.
WLAN=""
for dev in /sys/class/net/*; do
  if [[ -d $dev/wireless ]]; then
    WLAN=$(basename "$dev")
    break
  fi
done
if [[ -z $WLAN ]]; then
  log "no WiFi interface found on this machine - nothing to configure"
  exit 0
fi
log "using WiFi interface $WLAN"

# escape for double-quoted YAML scalars
esc() { printf '%s' "$1" | sed 's/\\/\\\\/g; s/"/\\"/g'; }

TMP=$(mktemp)
trap 'rm -f "$TMP"' EXIT

{
  echo "# Generated by kiosk-apply-wifi - do not edit (the display manager distributes"
  echo "# the WiFi details; this file is rewritten when they change)."
  echo "network:"
  echo "  version: 2"
  echo "  wifis:"
  echo "    $WLAN:"
  echo "      dhcp4: true"
  echo "      dhcp4-overrides:"
  echo "        route-metric: 4096"
  echo "      optional: true"
  echo "      access-points:"
  if [[ -n $PSK ]]; then
    echo "        \"$(esc "$SSID")\":"
    echo "          password: \"$(esc "$PSK")\""
  else
    echo "        \"$(esc "$SSID")\": {}"
  fi
} > "$TMP"

if [[ -f $YAML ]] && cmp -s "$TMP" "$YAML"; then
  install_wait_online_any   # boxes configured by an older helper version still need the override
  exit 0                    # unchanged - no netplan apply, no network blip
fi

install -m 600 -o root -g root "$TMP" "$YAML"

if netplan apply 2>&1; then
  install_wait_online_any
  log "WiFi configured for \"$SSID\" (wired stays preferred when connected)"
else
  # a bad apply must not leave a broken file for the next boot
  rm -f "$YAML"
  netplan apply 2>/dev/null || true
  log "netplan rejected the WiFi config - reverted"
  exit 1
fi
