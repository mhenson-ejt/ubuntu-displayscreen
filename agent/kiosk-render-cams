#!/bin/bash
#===============================================================================
# kiosk-render-cams - renders /etc/kiosk/cams.sh from /etc/kiosk/config.json
#
# Single source of truth for the mpv/layout logic, used by both the managed
# agent (config from the display manager) and standalone installs (config
# written by kiosk-setup.sh). Exits non-zero on invalid config without
# touching the existing cams.sh.
#
# config.json shape:
#   { "nvrIp": "...", "nvrPort": 554, "nvrUser": "...", "nvrPass": "...",
#     "layout": "1|2h|2v|4", "channels": [1,2,3,4], "subtype": 0|1,
#     "rotate": "none|left|right", "rotateOutput": "HDMI-1"|null }
#===============================================================================
set -euo pipefail

CONFIG=${1:-/etc/kiosk/config.json}
OUT=${2:-/etc/kiosk/cams.sh}

die() { echo "kiosk-render-cams: $*" >&2; exit 1; }

command -v jq >/dev/null 2>&1 || die "jq is not installed"
[[ -f $CONFIG ]] || die "config file not found: $CONFIG"
[[ -f /etc/kiosk/kiosk.conf ]] || die "/etc/kiosk/kiosk.conf missing (run kiosk-setup.sh)"
source /etc/kiosk/kiosk.conf   # provides KIOSK_USER
[[ -n ${KIOSK_USER:-} ]] || die "KIOSK_USER not set in /etc/kiosk/kiosk.conf"

jq -e . "$CONFIG" >/dev/null 2>&1 || die "config is not valid JSON"

NVR_IP=$(jq -r '.nvrIp // empty' "$CONFIG")
NVR_PORT=$(jq -r '.nvrPort // 554' "$CONFIG")
NVR_USER=$(jq -r '.nvrUser // empty' "$CONFIG")
NVR_PASS=$(jq -r '.nvrPass // empty' "$CONFIG")
LAYOUT=$(jq -r '.layout // empty' "$CONFIG")
SUBTYPE=$(jq -r '.subtype // 1' "$CONFIG")
ROTATE=$(jq -r '.rotate // "none"' "$CONFIG")
ROTATE_OUT=$(jq -r '.rotateOutput // empty' "$CONFIG")
readarray -t CH < <(jq -r '.channels[]?' "$CONFIG")

[[ -n $NVR_IP && -n $NVR_USER && -n $NVR_PASS ]] || die "nvrIp/nvrUser/nvrPass must be set"
case $LAYOUT in 1) NEED=1 ;; 2h|2v) NEED=2 ;; 4) NEED=4 ;; *) die "layout must be 1, 2h, 2v or 4" ;; esac
[[ ${#CH[@]} -eq $NEED ]] || die "layout '$LAYOUT' needs exactly $NEED channels, got ${#CH[@]}"
case $ROTATE in none|left|right) ;; *) die "rotate must be none, left or right" ;; esac
[[ $LAYOUT == 1 || $SUBTYPE == 1 ]] || SUBTYPE=1   # grids must use substreams

#--- URL-encode the password ---------------------------------------------------
urlencode() {
  local s=$1 out="" c hex
  for (( i=0; i<${#s}; i++ )); do
    c=${s:$i:1}
    case $c in [a-zA-Z0-9.~_-]) out+=$c ;; *) printf -v hex '%%%02X' "'$c"; out+=$hex ;; esac
  done
  echo "$out"
}
NVR_PASS_ENC=$(urlencode "$NVR_PASS")

URLBASE="rtsp://${NVR_USER}:${NVR_PASS_ENC}@${NVR_IP}:${NVR_PORT}/cam/realmonitor"

ROTATE_LINE="# no rotation"
if [[ $ROTATE != none ]]; then
  if [[ -n $ROTATE_OUT ]]; then
    ROTATE_LINE="xrandr --output $ROTATE_OUT --rotate $ROTATE"
  else
    # Auto-detect the first connected output at runtime
    ROTATE_LINE='OUT=$(xrandr | awk '"'"'/ connected/{print $1; exit}'"'"'); xrandr --output "$OUT" --rotate '"$ROTATE"
  fi
fi

MPV_COMMON='--fs --no-osc --no-input-default-bindings --no-keepaspect --really-quiet \
      --hwdec=auto --profile=low-latency --rtsp-transport=tcp'

case $LAYOUT in
  1)
    MPV_CMD="mpv $MPV_COMMON \\
      \"\${URL}?channel=${CH[0]}&subtype=${SUBTYPE}\""
    ;;
  2h)
    MPV_CMD="mpv $MPV_COMMON \\
      --lavfi-complex=\"[vid1][vid2]hstack[vo]\" \\
      --external-file=\"\${URL}?channel=${CH[1]}&subtype=${SUBTYPE}\" \\
      \"\${URL}?channel=${CH[0]}&subtype=${SUBTYPE}\""
    ;;
  2v)
    MPV_CMD="mpv $MPV_COMMON \\
      --lavfi-complex=\"[vid1][vid2]vstack[vo]\" \\
      --external-file=\"\${URL}?channel=${CH[1]}&subtype=${SUBTYPE}\" \\
      \"\${URL}?channel=${CH[0]}&subtype=${SUBTYPE}\""
    ;;
  4)
    MPV_CMD="mpv $MPV_COMMON \\
      --lavfi-complex=\"[vid1][vid2]hstack[top];[vid3][vid4]hstack[bottom];[top][bottom]vstack[vo]\" \\
      --external-file=\"\${URL}?channel=${CH[1]}&subtype=${SUBTYPE}\" \\
      --external-file=\"\${URL}?channel=${CH[2]}&subtype=${SUBTYPE}\" \\
      --external-file=\"\${URL}?channel=${CH[3]}&subtype=${SUBTYPE}\" \\
      \"\${URL}?channel=${CH[0]}&subtype=${SUBTYPE}\""
    ;;
esac

TMP=$(mktemp)
trap 'rm -f "$TMP"' EXIT

cat > "$TMP" <<EOF
#!/bin/bash
# Generated by kiosk-render-cams - do not edit (changes are overwritten)
export LIBVA_DRIVER_NAME=i965

xset s off
xset -dpms
xset s noblank

$ROTATE_LINE

URL="$URLBASE"

while true; do
  $MPV_CMD
  sleep 3
done
EOF

# cams.sh holds NVR credentials: kiosk user gets read+execute via group, others nothing
install -m 750 -o root -g "$KIOSK_USER" "$TMP" "$OUT"
echo "kiosk-render-cams: wrote $OUT (layout $LAYOUT, channels ${CH[*]}, subtype $SUBTYPE)"
